{
  "name": "animais-fantasticos",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build:css": "sass src/scss/style.scss dist/styles.css --no-source-map",
    "watch:css": "sass --watch src/scss/style.scss dist/styles.css --no-source-map",
    "dev": "npm run build:css && vite",
    "build": "npm run build:css && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "sass-embedded": "^1.98.0",
    "vite": "^8.0.1"
  },
  "dependencies": {
    "normalize.css": "^8.0.1",
    "sass": "^1.98.0"
  }
}
